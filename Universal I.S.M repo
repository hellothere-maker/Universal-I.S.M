local function notify(msg, isErr)
    notifText.Text = msg
    if isErr then
        notifContainer.BackgroundColor3 = Color3.fromRGB(70, 50, 50)
        notifBorder.BackgroundColor3 = Color3.fromRGB(120, 70, 70)
    else
        notifContainer.BackgroundColor3 = Color3.fromRGB(50, 70, 50)
        notifBorder.BackgroundColor3 = Color3.fromRGB(80, 110, 80)
    end
    notifContainer.Visible = true
    notifContainer.BackgroundTransparency = 1
    local fadeIn = tweenService:Create(notifContainer, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 0})
    fadeIn:Play()
    fadeIn.Completed:Wait()
    task.wait(2.5)
    local fadeOut = tweenService:Create(notifContainer, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 1})
    fadeOut:Play()
    fadeOut.Completed:Wait()
    notifContainer.Visible = false
end

local function copyToClip(text)
    if setclipboard then
        setclipboard(text)
        notify("copied: " .. text, false)
    elseif syn and syn.setclipboard then
        syn.setclipboard(text)
        notify("copied: " .. text, false)
    elseif syn and syn.clipboard and syn.clipboard.set then
        syn.clipboard.set(text)
        notify("copied: " .. text, false)
    else
        notify("clipboard not available", true)
    end
end

local function fetchUser(name)
    resultText.Text = "<i>fetching user data...</i>"
    resultFrame.Visible = true
    
    local url = "https://users.roblox.com/v1/usernames/users"
    local data = {usernames = {name}, excludeBannedUsers = false}
    local json = httpService:JSONEncode(data)
    
    local ok, res = pcall(function()
        if syn and syn.request then
            return syn.request({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = json})
        elseif request then
            return request({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = json})
        else
            return nil
        end
    end)
    
    if not ok or not res then
        resultText.Text = "<font color='#ff8888'>error: no request function</font>"
        notify("executor not supported", true)
        return
    end
    
    if res.StatusCode ~= 200 then
        resultText.Text = "<font color='#ff8888'>api error: " .. tostring(res.StatusCode) .. "</font>"
        notify("api request failed", true)
        return
    end
    
    local decoded = httpService:JSONDecode(res.Body)
    
    if not decoded.data or #decoded.data == 0 then
        resultText.Text = "<font color='#ffaa88'>user not found</font>\n\n\"" .. name .. "\" doesn't exist"
        notify("user not found", true)
        return
    end
    
    local user = decoded.data[1]
    local uid = user.id
    local uname = user.name
    local dname = user.displayName or uname
    
    local profileOk, profileRes = pcall(function()
        if syn and syn.request then
            return syn.request({Url = "https://users.roblox.com/v1/users/" .. uid, Method = "GET"})
        elseif request then
            return request({Url = "https://users.roblox.com/v1/users/" .. uid, Method = "GET"})
        else
            return nil
        end
    end)
    
    local desc = "no description"
    if profileOk and profileRes and profileRes.StatusCode == 200 then
        local profileData = httpService:JSONDecode(profileRes.Body)
        desc = profileData.description or "no description"
        if desc == "" then desc = "no description" end
    end
    
    local presenceOk, presenceRes = pcall(function()
        local pUrl = "https://presence.roblox.com/v1/presence/users"
        local pData = {userIds = {uid}}
        local pJson = httpService:JSONEncode(pData)
        if syn and syn.request then
            return syn.request({Url = pUrl, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = pJson})
        elseif request then
            return request({Url = pUrl, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = pJson})
        else
            return nil
        end
    end)
    
    local status = "offline"
    local color = "#aaaaaa"
    
    if presenceOk and presenceRes and presenceRes.StatusCode == 200 then
        local presenceData = httpService:JSONDecode(presenceRes.Body)
        if presenceData.userPresences and #presenceData.userPresences > 0 then
            local p = presenceData.userPresences[1]
            if p.userPresenceType == 1 then
                status = "online"
                color = "#88ff88"
            elseif p.userPresenceType == 2 then
                status = "in game"
                color = "#88ffaa"
            elseif p.userPresenceType == 3 then
                status = "in studio"
                color = "#ffaa88"
            end
        end
    end
    
    local shortDesc = desc
    if #shortDesc > 250 then
        shortDesc = shortDesc:sub(1, 247) .. "..."
    end
    
    resultText.Text = "<b>» " .. uname .. " (" .. dname .. ")</b>\n\n<font color='#dddddd'>description:</font>\n" .. shortDesc .. "\n\n<font color='#dddddd'>status:</font> <font color='" .. color .. "'>" .. status .. "</font>"
    notify("loaded: " .. uname, false)
end

local function checkHttpStatus()
    httpResult.Text = "<i>checking...</i>"
    local ok, res = pcall(function()
        if syn and syn.request then
            local resp = syn.request({Url = "https://httpbin.org/get", Method = "GET"})
            return resp.StatusCode == 200
        elseif request then
            local resp = request({Url = "https://httpbin.org/get", Method = "GET"})
            return resp.StatusCode == 200
        else
            return nil
        end
    end)
    
    if ok == nil then
        httpResult.Text = "<font color='#ff8888'>error: no request function</font>"
    elseif ok and res then
        httpResult.Text = "<font color='#88ff88'>http check completed!</font>"
        notify("http is enabled", false)
    else
        httpResult.Text = "<font color='#ff8888'>http is disabled or restricted</font>"
        notify("http is disabled", true)
    end
end

