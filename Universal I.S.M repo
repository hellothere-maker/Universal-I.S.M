local function startSpawnkill(targetName)
    local target = nil
    for _, plr in pairs(players:GetPlayers()) do
        if plr.Name:lower() == targetName:lower() then
            target = plr
            break
        end
    end
    
    if not target then
        spawnkillStatus.Text = "<font color='#ff8888'>player not found</font>"
        notify("player not found", true)
        return
    end
    
    if target == localPlayer then
        spawnkillStatus.Text = "<font color='#ff8888'>cant spawnkill yourself</font>"
        notify("cant spawnkill yourself", true)
        return
    end
    
    stopSpawnkill()
    
    spawnkillActive = true
    spawnkillTarget = target
    spawnkillStatus.Text = "<font color='#88ff88'>preparing spawnkill...</font>"
    
    local myChar = localPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        spawnkillOriginalPos = myChar.HumanoidRootPart.CFrame
        myChar.HumanoidRootPart.CFrame = CFrame.new(spawnkillSafe)
        local hum = myChar:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = true end
    end
    
    task.wait(4)
    
    spawnkillStatus.Text = "<font color='#88ff88'>spawnkilling: " .. target.Name .. "</font>"
    notify("spawnkilling " .. target.Name, false)
    
    local function flingDown(victim)
        if not spawnkillActive then return end
        local root = victim:FindFirstChild("HumanoidRootPart")
        if root then
            if spawnkillBodyVel then spawnkillBodyVel:Destroy() end
            spawnkillBodyVel = Instance.new("BodyVelocity")
            spawnkillBodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            spawnkillBodyVel.Velocity = Vector3.new(0, -200000, 0)
            spawnkillBodyVel.Parent = root
        end
    end
    
    local function teleportToVictim(victim)
        local myChar = localPlayer.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") and victim and victim:FindFirstChild("HumanoidRootPart") then
            local targetRoot = victim.HumanoidRootPart
            local targetVel = targetRoot.Velocity
            local speed = targetVel.Magnitude
            local offset = 3.5
            
            if speed > 50 then
                offset = 8
            elseif speed > 30 then
                offset = 6
            elseif speed > 16 then
                offset = 4.5
            end
            
            local direction = targetVel.Unit
            local predictedPos = targetRoot.Position
            if speed > 1 then
                predictedPos = targetRoot.Position + (direction * offset)
            end
            
            myChar.HumanoidRootPart.CFrame = CFrame.new(predictedPos)
        end
    end
    
    local function teleportToSafe()
        local myChar = localPlayer.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            myChar.HumanoidRootPart.CFrame = CFrame.new(spawnkillSafe)
        end
    end
    
    local function teleportToVoidSafe()
        local myChar = localPlayer.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            myChar.HumanoidRootPart.CFrame = CFrame.new(spawnkillVoidSafe)
            if spawnkillBodyVel then spawnkillBodyVel:Destroy() end
        end
    end
    
    local victimDied = false
    
    spawnkillTeleportLoop = runService.Heartbeat:Connect(function()
        if not spawnkillActive then return end
        
        local targetChar = spawnkillTarget.Character
        local myChar = localPlayer.Character
        
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            if myChar.HumanoidRootPart.Position.Y < -500 then
                if not spawnkillInVoid then
                    spawnkillInVoid = true
                    teleportToVoidSafe()
                    spawnkillStatus.Text = "<font color='#ffaa88'>waiting for respawn...</font>"
                end
                return
            else
                if spawnkillInVoid then
                    spawnkillInVoid = false
                end
            end
        end
        
        if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
            if victimDied then
                victimDied = false
                teleportToVictim(targetChar)
                flingDown(targetChar)
                spawnkillStatus.Text = "<font color='#88ff88'>spawnkilling: " .. spawnkillTarget.Name .. "</font>"
            else
                if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                    teleportToVictim(targetChar)
                    flingDown(targetChar)
                end
            end
        else
            if not victimDied then
                victimDied = true
                teleportToSafe()
                spawnkillStatus.Text = "<font color='#ffaa88'>victim died, waiting for respawn...</font>"
            end
        end
    end)
end

