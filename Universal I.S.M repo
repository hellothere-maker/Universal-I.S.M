local function updateTracers()
    for plr, line in pairs(tracers) do
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if onScreen then
                line.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                line.To = Vector2.new(pos.X, pos.Y)
                line.Visible = true
            else
                line.Visible = false
            end
        else
            line.Visible = false
        end
    end
end

local function updateSkeletons()
    for plr, data in pairs(skeletons) do
        local char = plr.Character
        if char then
            for _, lineData in pairs(data.lines) do
                local part1 = char:FindFirstChild(lineData.from)
                local part2 = char:FindFirstChild(lineData.to)
                if part1 and part2 then
                    local pos1, on1 = camera:WorldToViewportPoint(part1.Position)
                    local pos2, on2 = camera:WorldToViewportPoint(part2.Position)
                    if on1 and on2 then
                        lineData.line.From = Vector2.new(pos1.X, pos1.Y)
                        lineData.line.To = Vector2.new(pos2.X, pos2.Y)
                        lineData.line.Visible = true
                    else
                        lineData.line.Visible = false
                    end
                else
                    lineData.line.Visible = false
                end
            end
        else
            for _, lineData in pairs(data.lines) do
                lineData.line.Visible = false
            end
        end
    end
end

local function refreshESP()
    if not espActive then return end
    for _, plr in pairs(players:GetPlayers()) do
        if plr ~= localPlayer then
            if nameplatesActive then
                if not nameplates[plr] then
                    local np = makeNameplate(plr)
                    if np then nameplates[plr] = np end
                end
            else
                if nameplates[plr] then
                    pcall(function() nameplates[plr]:Destroy() end)
                    nameplates[plr] = nil
                end
            end
            if highlightsActive then
                if not highlights[plr] then
                    local hl = makeHighlight(plr)
                    if hl then highlights[plr] = hl end
                end
            else
                if highlights[plr] then
                    pcall(function() highlights[plr]:Destroy() end)
                    highlights[plr] = nil
                end
            end
            if tracersActive then
                if not tracers[plr] then
                    makeTracer(plr)
                end
            else
                if tracers[plr] then
                    pcall(function() tracers[plr]:Remove() end)
                    tracers[plr] = nil
                end
            end
            if skeletonActive then
                if not skeletons[plr] then
                    makeSkeleton(plr)
                end
            else
                if skeletons[plr] then
                    for _, lineData in pairs(skeletons[plr].lines) do
                        pcall(function() lineData.line:Remove() end)
                    end
                    skeletons[plr] = nil
                end
            end
        end
    end
end

local function espUpdate()
    if not espActive then return end
    refreshESP()
    if tracersActive then updateTracers() end
    if skeletonActive then updateSkeletons() end
end

