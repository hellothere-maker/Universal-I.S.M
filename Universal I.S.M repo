        if not playerRemovingConn then
            playerRemovingConn = players.PlayerRemoving:Connect(function(plr)
                if nameplates[plr] then pcall(function() nameplates[plr]:Destroy() end) nameplates[plr] = nil end
                if highlights[plr] then pcall(function() highlights[plr]:Destroy() end) highlights[plr] = nil end
                if tracers[plr] then pcall(function() tracers[plr]:Remove() end) tracers[plr] = nil end
                if skeletons[plr] then
                    for _, lineData in pairs(skeletons[plr].lines) do pcall(function() lineData.line:Remove() end) end
                    skeletons[plr] = nil
                end
            end)
        end
    else
        espMasterBtn.Text = "enable esp"
        espMasterBtn.BackgroundColor3 = Color3.fromRGB(70, 100, 70)
        espStatus.Text = "disabled"
        espStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
        clearESP()
        if espLoop then
            espLoop:Disconnect()
            espLoop = nil
        end
        if playerAddedConn then
            playerAddedConn:Disconnect()
            playerAddedConn = nil
        end
        if playerRemovingConn then
            playerRemovingConn:Disconnect()
            playerRemovingConn = nil
        end
    end
end

local function updateButtonStyle(btn, state, label)
    if state then
        btn.Text = label .. " on"
        btn.BackgroundColor3 = Color3.fromRGB(70, 100, 70)
    else
        btn.Text = label
        btn.BackgroundColor3 = Color3.fromRGB(52, 52, 52)
    end
end

