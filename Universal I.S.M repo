    end
    
    task.wait(0.3)
    
    flingerStatus.Text = "<font color='#88ff88'>flinging: " .. target.Name .. "</font>"
    notify("flinging " .. target.Name, false)
    
    local function setupFling(character)
        if not flingActive then return end
        if character ~= localPlayer.Character then return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            if bodyVel then bodyVel:Destroy() end
            bodyVel = Instance.new("BodyVelocity")
            bodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bodyVel.Velocity = Vector3.new(200000, 200000, 200000)
            bodyVel.Parent = rootPart
            local hum = character:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand = true end
        end
    end
    
    charRemoving = localPlayer.CharacterRemoving:Connect(function()
        if flingActive then stopFling(false) end
    end)
    
    charAdded = localPlayer.CharacterAdded:Connect(function(char)
        if flingActive then
            task.wait(0.1)
            setupFling(char)
        end
    end)
    
    setupFling(localPlayer.Character)
    
    flingLoop = runService.Heartbeat:Connect(function()
        if not flingActive then return end
        local targetChar = target.Character
        local myChar = localPlayer.Character
        if targetChar and targetChar:FindFirstChild("HumanoidRootPart") and myChar and myChar:FindFirstChild("HumanoidRootPart") then
            local targetRoot = targetChar.HumanoidRootPart
            local targetVel = targetRoot.Velocity
            local speed = targetVel.Magnitude
            local offset = 3.5
            
            if speed > 50 then
                offset = 8
            elseif speed > 30 then
                offset = 6
            elseif speed > 16 then
                offset = 4.5
            end
            
            local direction = targetVel.Unit
            local predictedPos = targetRoot.Position
            if speed > 1 then
                predictedPos = targetRoot.Position + (direction * offset)
            end
            
            local myRoot = myChar.HumanoidRootPart
            myRoot.CFrame = CFrame.new(predictedPos)
            
            if bodyVel and bodyVel.Parent then
                local randomDir = Vector3.new(math.random(-200000, 200000), math.random(50000, 300000), math.random(-200000, 200000))
                bodyVel.Velocity = randomDir
            end
        end
    end)
    
    flingCheck = runService.Heartbeat:Connect(function()
        if not flingActive then return end
        local targetChar = target.Character
        if targetChar and targetChar:FindFirstChild("HumanoidRootPart") and victimStartPos then
            local currentPos = targetChar.HumanoidRootPart.Position
            local dist = (currentPos - victimStartPos).Magnitude
            if dist > 300 then
                notify(target.Name .. " got flung!", false)
                stopFling(true)
            end
        end
    end)
end

