        return
    end
    
    if target == localPlayer then
        flingerStatus.Text = "<font color='#ff8888'>cant fling yourself</font>"
        notify("cant fling yourself", true)
        return
    end
    
    stopFling(false)
    
    local myChar = localPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        originalPos = myChar.HumanoidRootPart.CFrame
        local hum = myChar:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = true end
    end
    
    local targetChar = target.Character
    if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
        victimStartPos = targetChar.HumanoidRootPart.Position
    end
    
    flingActive = true
    flingerStatus.Text = "<font color='#88ff88'>preparing...</font>"
    
    local myChar2 = localPlayer.Character
    if myChar2 and myChar2:FindFirstChild("HumanoidRootPart") then
